# Claude API（記事自動生成用 / 任意）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# A8.net 自動発見用のセッションCookie（auto_discover.py 用 / 任意）
# A8管理画面にログイン後、ブラウザDevToolsで Cookie 文字列を取得して貼り付け
A8_COOKIE=PHPSESSID=xxxxx; a8_logged_in=1; ...

# 公開サイトURL（GitHub Pages or 独自ドメイン）
SITE_URL=https://subzukan.com

# Google Analytics 4 測定ID
# https://analytics.google.com/ → 管理 → データストリーム → 測定ID（G-で始まる）
GA_ID=

# Google Search Console 所有権確認コード（HTMLタグ方式）
# https://search.google.com/search-console → プロパティ追加（URLプレフィックス） →
# HTMLタグの content="..." の中身（"..."を含めない）をここに貼る
GSC_VERIFICATION=
